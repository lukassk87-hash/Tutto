        font-size: 1.06rem;
        border-width: 2px;
        min-width: 98%;
        margin: 11px 0 0 0;
        border-radius: 15px;
      }
      #footerWuerfel {
        padding: 16px 9px;
        max-width: 100vw;
      }
    }
    input#nameInput {
      border-radius: 10px;
      border: 2px solid #2A75BB;
      padding: 11px 12px;
      font-size: 1.14rem;
      margin: 10px auto 18px auto;
      width: 92%;
      box-sizing: border-box;
      font-family: 'Fredoka One', Arial, sans-serif;
    }
