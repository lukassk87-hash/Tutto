      padding: 20px;
      text-align: center;
      margin: 0;
      min-height: 100vh;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    h1 {
      color: #3C5AA6;
      text-shadow: 2px 2px 0 #FFCB05, 0 2px #2A75BB;
      font-size: 2.2rem;
      margin-bottom: 18px;
      margin-top: 1.2rem;
      font-family: 'Fredoka One', Arial, sans-serif;
      font-weight: 900;
      letter-spacing: 1px;
    }
    #game {
      background: #fff;
      border-radius: 19px;
      box-shadow: 0 6px 23px rgba(44,90,166,0.22);
      padding: 16px 8px 16px 8px;
      max-width: 420px;
      width: 100%;
      margin: 0 auto;
      font-size: 1.085rem;
      color: #222;
      line-height: 1.45;
      margin-bottom: 140px;
      word-wrap: break-word;
      white-space: pre-wrap;
      box-sizing: border-box;
      position: relative;
      border: 4px solid #2A75BB;
    }
    #game p { margin: 9px 0; }
    .desc {
      color: #2A75BB;
      font-size: .98em;
      margin-bottom: 6px;
      font-style: italic;
      font-weight: 400;
    }
    .pokemon-img {
      height: 90px;
      vertical-align: middle;
      margin-right: 9px;
      image-rendering: pixelated;
      max-width:90px;
    }
    hr {
      border: 0;
      border-top: 2px solid #3C5AA6;
      margin: 16px 0;
    }
    .btn {
      background: #FFF;
      border: 3px solid #2A75BB;
      color: #222;
      font-family: 'Fredoka One', Arial, sans-serif;
      font-weight: bold;
      border-radius: 15px;
      padding: 15px 18px;
      margin: 12px auto 0 auto;
      box-shadow: 0 3px 8px rgba(44,90,166,0.10);
      display: block;
      width: 98%;
      max-width: 99%;
      box-sizing: border-box;
      font-size: 1.15rem;
      cursor: pointer;
      transition: background .2s, color .2s, box-shadow .2s;
      text-align: center;
      letter-spacing: .5px;
    }
    .btn:active, .btn:focus {
      background: #2A75BB;
      color: #fff;
      outline: none;
    }
    .btn:hover {
      background: #3C5AA6;
      color: #fff;
      box-shadow: 0 6px 16px rgba(44,90,166,0.22);
    }
    .btn:disabled {
      opacity: .59;
      cursor: not-allowed;
    }
    .btn.ort {
      background: linear-gradient(90deg, #FFCB05 80%, #2A75BB 100%);
      border: 3px solid #3C5AA6;
      color: #222;
      text-align: left;
      font-size: 1.08rem;
      font-weight: bold;
      padding: 15px 18px;
      margin: 12px auto 0 auto;
      box-sizing: border-box;
      width: 98%;
      border-radius: 16px;
      box-shadow: 0 3px 14px rgba(44,90,166,0.09);
      min-height: 56px;
    }
    .btn.ort:hover, .btn.ort:focus {
      background: linear-gradient(90deg, #2A75BB 70%, #FFCB05 100%);
      color: #fff;
    }
    #footerWuerfel {
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      bottom: 14px;
      background: #fff;
      border: 3px solid #3C5AA6;
      border-radius: 17px;
      padding: 18px 14px 18px 14px;
      z-index: 1000;
      width: 96vw;
      max-width: 420px;
      box-shadow: 0 4px 22px rgba(44,90,166,0.13);
      text-align: center;
      font-family: 'Fredoka One', Arial, sans-serif;
    }
    #wuerfelTitel {
      font-weight: 700;
      font-size: 1.12rem;
      margin-bottom: 5px;
      color: #2A75BB;
      letter-spacing: .5px;
    }
    #wuerfelGewinn {
      font-weight: 550;
      margin-bottom: 8px;
      color: #3C5AA6;
    }
    #wuerfelAnzeige {
      font-size: 2.6rem;
      margin-bottom: 7px;
      user-select: none;
    }
    #wuerfelErgebnis {
      font-weight: 700;
      font-size: 1.25rem;
      color: #222;
      min-height: 1.3em;
      margin-bottom: 10px;
    }
    @media (max-width: 600px) {
      h1 { font-size: 1.33rem; }
      #game {
        font-size: 0.98rem;
        padding: 9px 1vw 12px 1vw;
        margin-bottom: 155px;
        min-width: unset;
      }
      .btn, .btn.ort {
